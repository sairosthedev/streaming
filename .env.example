# Copy this file to .env and fill it in.
# .env is gitignored — your camera password never gets committed.

# ---------------------------------------------------------------------------
# The camera. Used by BOTH the local server (npm start) and the Vercel agent
# (npm run agent).
# ---------------------------------------------------------------------------

# The RTSP URL you paste into VLC.
#   rtsp://admin:pass@192.168.1.64:554/Streaming/Channels/101              (Hikvision)
#   rtsp://admin:pass@192.168.1.10:554/cam/realmonitor?channel=1&subtype=0 (Dahua)
# URL-encode special characters in the password: @ -> %40, : -> %3A, / -> %2F
RTSP_URL=rtsp://username:password@192.168.1.100:554/stream1

# "tcp" is more reliable than "udp" over WiFi.
RTSP_TRANSPORT=tcp

# "copy" repackages the camera's H.264 without re-encoding (near-zero CPU).
# Use "transcode" only if the camera sends H.265/HEVC, which browsers can't play.
# `npm run probe` tells you which.
VIDEO_MODE=copy
TRANSCODE_BITRATE=1500k
TRANSCODE_SCALE=1280:-2

# ---------------------------------------------------------------------------
# Vercel agent (npm run agent). Not needed for the purely local setup.
# ---------------------------------------------------------------------------

# From your Vercel project: Storage > Blob > .env.local tab.
# This token can write to your Blob store — treat it like a password.
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Local-only server (npm start). Not used by the Vercel app.
# ---------------------------------------------------------------------------

PORT=8080

# Blank = no password. Anyone with the URL can watch. Set it before sharing.
# NOTE: the Vercel app reads VIEW_PASSWORD from Vercel's env vars, not this file.
VIEW_PASSWORD=

# Seconds to keep streaming after the last viewer closes the page. The camera
# and CPU idle when nobody is watching; opening the page starts it again.
# Set to 0 to stream continuously regardless of viewers.
IDLE_TIMEOUT=300

# ---------------------------------------------------------------------------
# Permanent URL via a named Cloudflare Tunnel. Leave both blank to get a random
# trycloudflare.com URL that changes on every restart.
#
# One-time setup (needs a domain on Cloudflare):
#   cloudflared tunnel login
#   cloudflared tunnel create <name>
#   cloudflared tunnel route dns <name> camera.yourdomain.com
# ---------------------------------------------------------------------------
TUNNEL_NAME=
TUNNEL_HOSTNAME=

# ---------------------------------------------------------------------------
# Camera registry (optional). With this set, cameras are loaded from the
# `cameras` collection in MongoDB instead of the single RTSP_URL above, and you
# manage them with `npm run cameras`. Leave blank to run the single .env camera.
#
# Use the standard mongodb:// form with explicit hosts if your machine's DNS
# fails SRV lookups (symptom: "querySrv ECONNREFUSED" from mongodb+srv:// URIs).
# ---------------------------------------------------------------------------
MONGODB_URI=
