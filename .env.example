# Copy this file to .env and fill in your values.
# .env is gitignored — your camera password never gets committed.

# The RTSP URL you currently paste into VLC.
# Examples:
#   rtsp://admin:mypassword@192.168.1.64:554/Streaming/Channels/101   (Hikvision)
#   rtsp://admin:mypassword@192.168.1.10:554/cam/realmonitor?channel=1&subtype=0  (Dahua)
#   rtsp://user:pass@192.168.1.20:554/live/ch0                        (generic)
RTSP_URL=rtsp://username:password@192.168.1.100:554/stream1

# Port the local web server listens on.
PORT=8080

# Transport for the RTSP pull. "tcp" is far more reliable than "udp" over WiFi.
RTSP_TRANSPORT=tcp

# Leave blank for no password. If set, viewers must enter it before the feed loads.
# Anyone with your public URL can watch when this is blank — set it if that URL is shared.
VIEW_PASSWORD=

# "copy" re-packages the camera's existing H.264 without re-encoding: near-zero CPU,
# best quality, and what you want in almost every case.
# Switch to "transcode" only if the player shows a black screen or the camera emits
# H.265/HEVC, which browsers cannot play.
VIDEO_MODE=copy

# Only used when VIDEO_MODE=transcode.
TRANSCODE_BITRATE=1500k
TRANSCODE_SCALE=1280:-2
